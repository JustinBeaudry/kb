{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Cairn trust boundary — best-effort deny rules for untrusted vault surfaces. Sanctioned access goes through `cairn recall/get/list-topics` (curated) and `cairn read-raw/read-session` (ask-gated). Bash denies enumerate common readers; the R2a self-test (hooks/security-self-test) is the regression detector for the overall boundary.",
  "permissions": {
    "deny": [
      "Read(**/cairn/raw/**)",
      "Read(**/cairn/sessions/**)",
      "Read(**/cairn/.cairn/*.jsonl)",
      "Read(**/cairn/.cairn/*.jsonl.1)",
      "Read(~/cairn/raw/**)",
      "Read(~/cairn/sessions/**)",
      "Read(~/cairn/.cairn/*.jsonl)",
      "Read(~/cairn/.cairn/*.jsonl.1)",

      "Grep(**/cairn/raw/**)",
      "Grep(**/cairn/sessions/**)",
      "Grep(**/cairn/.cairn/**)",
      "Grep(~/cairn/raw/**)",
      "Grep(~/cairn/sessions/**)",
      "Grep(~/cairn/.cairn/**)",

      "Glob(**/cairn/raw/**)",
      "Glob(**/cairn/sessions/**)",
      "Glob(**/cairn/.cairn/**)",
      "Glob(~/cairn/raw/**)",
      "Glob(~/cairn/sessions/**)",
      "Glob(~/cairn/.cairn/**)",

      "Bash(cat *cairn/raw/*)",
      "Bash(cat *cairn/sessions/*)",
      "Bash(cat *cairn/.cairn/*.jsonl*)",
      "Bash(head *cairn/raw/*)",
      "Bash(head *cairn/sessions/*)",
      "Bash(head *cairn/.cairn/*.jsonl*)",
      "Bash(tail *cairn/raw/*)",
      "Bash(tail *cairn/sessions/*)",
      "Bash(tail *cairn/.cairn/*.jsonl*)",
      "Bash(less *cairn/raw/*)",
      "Bash(less *cairn/sessions/*)",
      "Bash(more *cairn/raw/*)",
      "Bash(more *cairn/sessions/*)",
      "Bash(grep *cairn/raw/*)",
      "Bash(grep *cairn/sessions/*)",
      "Bash(grep *cairn/.cairn/*)",
      "Bash(rg *cairn/raw/*)",
      "Bash(rg *cairn/sessions/*)",
      "Bash(rg *cairn/.cairn/*)",
      "Bash(awk *cairn/raw/*)",
      "Bash(awk *cairn/sessions/*)",
      "Bash(sed *cairn/raw/*)",
      "Bash(sed *cairn/sessions/*)",
      "Bash(cut *cairn/raw/*)",
      "Bash(cut *cairn/sessions/*)",
      "Bash(xxd *cairn/raw/*)",
      "Bash(xxd *cairn/sessions/*)",
      "Bash(od *cairn/raw/*)",
      "Bash(od *cairn/sessions/*)",
      "Bash(strings *cairn/raw/*)",
      "Bash(strings *cairn/sessions/*)",
      "Bash(bat *cairn/raw/*)",
      "Bash(bat *cairn/sessions/*)",
      "Bash(python *cairn/raw/*)",
      "Bash(python3 *cairn/raw/*)",
      "Bash(ruby *cairn/raw/*)",
      "Bash(node *cairn/raw/*)",
      "Bash(bun *cairn/raw/*)"
    ]
  }
}
